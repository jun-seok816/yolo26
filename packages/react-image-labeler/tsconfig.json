{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["DOM", "ES2019"],
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "sourceMap": true,
    "typeRoots": ["./node_modules/@types", "../../front-end/node_modules/@types"],
    "paths": {
      "react": ["./node_modules/react", "../../front-end/node_modules/react"],
      "react-dom": ["./node_modules/react-dom", "../../front-end/node_modules/react-dom"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
